#!/usr/bin/env bash
# md2pdf.sh — build a PDF from Markdown in the fleet style.
# Usage: ./md2pdf.sh input.md [output.pdf]
# Canon: proj_arch/patterns/pdf-reports.md. PDF is opt-in — build only on explicit request.
set -euo pipefail

IN="${1:?Provide an input .md file: ./md2pdf.sh input.md [output.pdf]}"
OUT="${2:-${IN%.*}.pdf}"
DIR="$(cd "$(dirname "$0")" && pwd)"

pandoc "$IN" -o "$OUT" -d "$DIR/pandoc-pdf.yaml"

echo "Done: $OUT"
